# Database — Turso (cloud SQLite)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# AI API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
OPENAI_API_KEY=your-openai-api-key-here

# Cron + ingestion automation
CRON_SECRET=your-cron-secret
DISCORD_ANNOUNCEMENTS_WEBHOOK_URL=https://discord.com/api/webhooks/your-id/your-token
DISCORD_YAP_WEBHOOK_URL=https://discord.com/api/webhooks/your-id/your-token
DISCORD_WEBHOOK_USERNAME=Latent Space Hub
DISCORD_WEBHOOK_AVATAR_URL=https://your-cdn-or-public-url/latent-space-hub-avatar.png
# DISCORD_SIG_USER_ID is not used for automated kickoff (Slop-only) — kept for slash commands in latent-space-bots
DISCORD_SIG_USER_ID=123456789012345678
DISCORD_SLOP_USER_ID=123456789012345678
# Deterministic bot kickoff (preferred over webhook mention trigger)
DISCORD_BOT_KICKOFF_URL=http://your-bot-service:8787/internal/kickoff
DISCORD_BOT_KICKOFF_SECRET=your-shared-secret
DISCORD_BOT_TALK_CHANNEL_ID=123456789012345678
DISCORD_BOT_KICKOFF_EXCHANGES=2
# Set true only if you still want legacy yap webhook messages when deterministic kickoff is enabled
DISCORD_ENABLE_LEGACY_YAP_WEBHOOK=false
LATENTSPACE_PODCAST_CHANNEL_ID=UCxBcwypKK-W3GHd_RZ9FZrQ
LATENTSPACETV_CHANNEL_ID=your-latentspacetv-channel-id

# Application Configuration
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEPLOYMENT_MODE=local
